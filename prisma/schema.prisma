// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  categories   Category[]
  expenses     Expense[]
  budgets      Budget[]
  recurring    RecurringTemplate[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   // palette token: sapphire | seaweed | amethyst | lavender
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
  budgets   Budget[]
  recurring RecurringTemplate[]

  @@unique([userId, name])
  @@index([userId])
}

model RecurringTemplate {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  amountCents Int
  frequency   String          // weekly | monthly | yearly
  anchorDay   Int             // weekly: weekday 0-6; monthly: day 1-31; yearly: month*100+day
  startDate   DateTime        @db.Date
  active      Boolean         @default(true)
  postings    PostingLedger[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([categoryId])
}

model PostingLedger {
  id            String            @id @default(cuid())
  templateId    String
  template      RecurringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scheduledDate DateTime          @db.Date
  expenseId     String?
  createdAt     DateTime          @default(now())

  @@unique([templateId, scheduledDate])
}

model Budget {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amountCents Int
  timespan    String   // monthly | yearly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, categoryId, timespan])
  @@index([userId])
  @@index([categoryId])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amountCents Int
  description String
  date        DateTime @db.Date
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@index([categoryId])
}
